# Environment Configuration for Automotive Predictive Maintenance
# Phase 1 + Phase 2 (ClickHouse Integration & FastAPI)
# Copy this file to .env and adjust values as needed

# ========================================
# PHASE 1 - MQTT & Kafka Configuration
# ========================================

# MQTT Broker
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=/vehicle/+/telemetry

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka Topics
KAFKA_TOPIC_RAW=vehicle_telemetry_raw
KAFKA_TOPIC_CLEAN=vehicle_telemetry_clean
KAFKA_TOPIC_ANOMALIES=vehicle_anomalies

# Consumer Configuration
CONSUMER_GROUP=telemetry_cleaner_group

# ========================================
# Vehicle Simulator Configuration
# ========================================

# Number of vehicles to simulate (10-50)
NUM_VEHICLES=20

# Publishing intervals in seconds
MIN_PUBLISH_INTERVAL=1.0
MAX_PUBLISH_INTERVAL=5.0

# Probability of injecting an anomaly (0.0 - 1.0)
ANOMALY_PROBABILITY=0.05

# ========================================
# Data Processing Configuration
# ========================================

# Rolling window size for statistics
ROLLING_WINDOW_SIZE=10

# ========================================
# PHASE 2 - ClickHouse Configuration
# ========================================

# ClickHouse Database
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_pass
CLICKHOUSE_DATABASE=telemetry_db

# ClickHouse Ingestion Settings
CLICKHOUSE_BATCH_SIZE=100
CLICKHOUSE_BATCH_TIMEOUT=5.0

# ========================================
# PHASE 2 - FastAPI Configuration
# ========================================

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000

# ========================================
# Retry Configuration
# ========================================

MAX_RETRIES=3
RETRY_BACKOFF=2.0

# ========================================
# Logging Configuration
# ========================================

# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
